---
import { archiveConfig } from '@config/archives';
import { getPostHref, slugifyTag, type BlogPost } from '@lib/posts';
import FormattedDate from './FormattedDate.astro';
import PostCover from './PostCover.astro';
import TagList from './TagList.astro';

interface Props {
  posts: BlogPost[];
}

const { posts } = Astro.props;
---

<div class="archive-post-list" data-archive-post-list>
  {
    posts.map((post) => (
      <article
        class="archive-post"
        data-post-card
        data-category={post.data.category ? slugifyTag(post.data.category) : ''}
        data-tags={post.data.tags.map(slugifyTag).join('|')}
        data-year={String(post.data.pubDate.getFullYear())}
      >
        <a class="archive-cover" href={getPostHref(post)} tabindex="-1" aria-hidden="true">
          <PostCover
            title={post.data.title}
            category={post.data.category}
            tags={post.data.tags}
            tone={post.data.cover.tone}
            label={post.data.cover.label}
            image={post.data.cover.image}
            imageUrl={post.data.cover.url}
            alt={post.data.cover.alt}
          />
        </a>
        <div class="archive-copy">
          <div class="archive-meta">
            {post.data.category && <span>{post.data.category}</span>}
            {archiveConfig.showPublishedDate && <FormattedDate date={post.data.pubDate} />}
          </div>
          <h2>
            <a href={getPostHref(post)}>{post.data.title}</a>
          </h2>
          {archiveConfig.showTags && post.data.tags.length > 0 && (
            <div class="archive-tags">
              <TagList tags={post.data.tags} />
            </div>
          )}
          <p>{post.data.description}</p>
        </div>
        <a
          class="archive-link"
          href={getPostHref(post)}
          aria-label={`阅读文章：${post.data.title}`}
        >
          <span aria-hidden="true">→</span>
        </a>
      </article>
    ))
  }
</div>

<style>
  .archive-post-list {
    display: grid;
  }

  .archive-post {
    display: grid;
    grid-template-columns: 10rem minmax(0, 1fr) auto;
    gap: clamp(0.9rem, 2vw, 1.35rem);
    align-items: center;
    min-width: 0;
    padding: clamp(0.9rem, 2vw, 1.3rem);
    transition: background var(--motion-duration) var(--motion-easing);
  }

  .archive-post[hidden] {
    display: none;
  }

  .archive-post + .archive-post {
    border-top: 1px dashed rgb(159 146 125 / 46%);
  }

  .archive-post:hover {
    background: rgb(25 200 185 / 6%);
  }

  .archive-cover {
    display: block;
    border-radius: var(--radius-base);
  }

  .archive-cover :global(.post-cover) {
    aspect-ratio: 2 / 1;
  }

  /* The generated 2:1 covers are rendered as compact archive thumbnails.
   * Scale their copy to the thumbnail itself so it remains fully visible. */
  .archive-cover :global(.cover-copy) {
    top: 9%;
    gap: 0.18rem;
  }

  .archive-cover :global(.cover-label) {
    padding: 0.12rem 0.34rem;
    font-size: 0.42rem;
    letter-spacing: 0.06em;
  }

  .archive-cover :global(.generated-cover strong) {
    font-size: clamp(0.82rem, 1.35vw, 1.08rem);
    line-height: 1.05;
  }

  .archive-cover :global(.cover-tag) {
    display: none;
  }

  .archive-copy {
    min-width: 0;
  }

  .archive-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 0.7rem;
    align-items: center;
    color: var(--color-text-muted);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .archive-meta span:first-child {
    border-radius: var(--radius-pill);
    background: rgb(247 205 103 / 25%);
    padding: 0.18rem 0.48rem;
    color: #936817;
  }

  .archive-tags {
    margin-top: 0.45rem;
  }

  .archive-tags :global([class*='animal-tag']) {
    font-size: 0.66rem;
  }

  h2 {
    overflow: hidden;
    margin: 0.42rem 0 0;
    color: var(--color-text);
    font-size: clamp(1.05rem, 2vw, 1.32rem);
    line-height: 1.35;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  h2 a {
    color: inherit;
    text-decoration: none;
  }

  h2 a:hover {
    color: #0e988d;
  }

  p {
    display: -webkit-box;
    overflow: hidden;
    margin: 0.42rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.86rem;
    line-height: 1.55;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .archive-link {
    display: grid;
    width: 2.25rem;
    height: 2.25rem;
    place-items: center;
    border-radius: 50%;
    background: rgb(25 200 185 / 12%);
    color: #0e988d;
    font-size: 1.2rem;
    font-weight: 900;
    text-decoration: none;
    transition:
      background var(--motion-duration) var(--motion-easing),
      color var(--motion-duration) var(--motion-easing),
      transform var(--motion-duration) var(--motion-easing);
  }

  .archive-post:hover .archive-link,
  .archive-link:focus-visible {
    transform: translateX(0.18rem);
    background: #19c8b9;
    color: #fff;
  }

  /* Category badges need their own high-contrast treatment: unlike a
   * decorative tag, they are metadata users scan while comparing posts. */
  :global(:root[data-theme='dark']) .archive-post + .archive-post {
    border-color: rgb(172 160 143 / 24%);
  }

  :global(:root[data-theme='dark']) .archive-post:hover {
    background: rgb(84 211 192 / 7%);
  }

  :global(:root[data-theme='dark']) .archive-meta span:first-child {
    background: rgb(231 189 99 / 18%);
    color: #f2d58e;
    box-shadow: inset 0 0 0 1px rgb(231 189 99 / 22%);
  }

  :global(:root[data-theme='dark']) h2 a:hover,
  :global(:root[data-theme='dark']) .archive-link {
    color: var(--color-primary);
  }

  :global(:root[data-theme='dark']) .archive-link {
    background: rgb(84 211 192 / 15%);
  }

  :global(:root[data-theme='dark']) .archive-post:hover .archive-link,
  :global(:root[data-theme='dark']) .archive-link:focus-visible {
    background: #277e72;
    color: #fff9eb;
  }

  @media (max-width: 38rem) {
    .archive-post {
      grid-template-columns: 6.5rem minmax(0, 1fr);
      gap: 0.8rem;
    }

    .archive-link {
      display: none;
    }

    h2 {
      white-space: normal;
    }

    p {
      -webkit-line-clamp: 2;
    }
  }
</style>
