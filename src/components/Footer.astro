---
import { analyticsConfig, navigationConfig, siteConfig } from '@config/index';
import { Divider, Footer as AnimalFooter } from './animal';
import { SiBilibili, SiGithub } from 'react-icons/si';

const year = new Date().getFullYear();
const yearLabel =
  year === siteConfig.footer.copyrightStartYear
    ? String(year)
    : `${siteConfig.footer.copyrightStartYear}–${year}`;

const getIcon = (iconName?: string) => {
  if (iconName === 'github') return SiGithub;
  if (iconName === 'bilibili') return SiBilibili;
  return null;
};
---

<footer>
  <div class="island-decoration" aria-hidden="true">
    <AnimalFooter type="tree" />
  </div>
  <div class="container footer-inner">
    <div>
      <strong>{siteConfig.name}</strong>
      <p>{siteConfig.footer.message}</p>
    </div>
    <nav aria-label="页脚导航">
      {navigationConfig.utility.map((item) => <a href={item.href}>{item.label}</a>)}
      {
        siteConfig.socialLinks.map((item) => {
          const IconComponent = getIcon(item.icon);
          return (
            <a
              href={item.href}
              aria-label={item.ariaLabel}
              title={item.label}
              target={item.external ? '_blank' : undefined}
              rel={item.external ? 'noreferrer' : undefined}
              class="social-link"
            >
              {IconComponent ? <IconComponent size={20} /> : item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
  <div class="container divider" aria-hidden="true"><Divider type="dashed-teal" /></div>
  <div class="container copyright">
    <div class="copyright-left">
      <span>© {yearLabel} {siteConfig.author.name}</span>
      {
        analyticsConfig.publicCounter.enabled && (
          <span class="visit-count" aria-live="polite" title="公开计数由不蒜子提供">
            总访问 <strong id="busuanzi_site_pv">统计中…</strong> 次
            <span aria-hidden="true">·</span>
            总访客 <strong id="busuanzi_site_uv">统计中…</strong> 人
          </span>
        )
      }
      <span class="credits">
        <a href={siteConfig.footer.themeCredit.href} target="_blank" rel="noreferrer">
          {siteConfig.footer.themeCredit.label}
        </a>
        <span aria-hidden="true">·</span>
        <a href={siteConfig.footer.uiCredit.href} target="_blank" rel="noreferrer">
          {siteConfig.footer.uiCredit.label}
        </a>
      </span>
    </div>
    {
      siteConfig.footer.icp && (
        <div class="copyright-right">
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noreferrer" class="icp-link">
            {siteConfig.footer.icp}
          </a>
        </div>
      )
    }
  </div>
</footer>

<style>
  footer {
    margin-top: 6rem;
    padding-block: 0 1.5rem;
    background: var(--color-surface-secondary);
  }

  .island-decoration {
    overflow: hidden;
    transform: translateY(-78px);
    margin-bottom: -56px;
    pointer-events: none;
  }

  .island-decoration :global([class*='animal-footer']) {
    width: 100%;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
  }

  strong {
    color: var(--color-text);
    font-size: 1.15rem;
  }

  p {
    margin: 0.3rem 0 0;
  }

  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .social-link:hover {
    color: var(--color-text);
  }

  .copyright {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    margin-top: 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
  }

  .copyright-left {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.7rem;
  }

  .credits {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .visit-count {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    align-items: baseline;
  }

  .visit-count strong {
    color: var(--color-text);
    font-size: inherit;
    font-weight: 900;
  }

  .credits a,
  .icp-link {
    color: inherit;
    text-underline-offset: 0.16em;
  }

  .credits a:hover,
  .icp-link:hover {
    color: var(--color-text);
  }

  .divider {
    margin-top: 1.25rem;
  }

  @media (max-width: 40rem) {
    .footer-inner {
      flex-direction: column;
    }
  }
</style>
