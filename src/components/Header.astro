---
import { navigationConfig, siteConfig } from '@config/index';
import GlobalSearch from '@components/react/GlobalSearch';

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === href : pathname === href || pathname.startsWith(href);
---

<header class="site-header" data-scroll-header>
  <div class="header-surface">
    <div class="header-inner">
      {
        navigationConfig.header.showBrand && (
          <a class="brand" href="/" aria-label={`${siteConfig.name} 首页`}>
            <span class="brand-mark" aria-hidden="true">
              <img src={siteConfig.branding.logoSrc} alt="" />
            </span>
            <span class="brand-copy">
              <strong>{siteConfig.name}</strong>
              <small>{siteConfig.slogan}</small>
            </span>
          </a>
        )
      }
      <div class="primary-navigation" id="primary-navigation">
        <nav aria-label="主导航">
          <ul>
            {
              navigationConfig.primary.map((item) => (
                <li>
                  <a href={item.href} aria-current={isActive(item.href) ? 'page' : undefined}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>
        {
          navigationConfig.search.enabled && (
            <GlobalSearch
              indexUrl={navigationConfig.search.indexUrl}
              config={navigationConfig.search}
              client:load
            />
          )
        }
      </div>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="切换至暗色模式">
        <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true"
          ><circle cx="12" cy="12" r="4"></circle><path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path></svg
        >
        <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true"
          ><path d="M20.4 15.5A8.5 8.5 0 0 1 8.5 3.6 8.5 8.5 0 1 0 20.4 15.5Z"></path></svg
        >
        <svg class="theme-icon theme-icon-system" viewBox="0 0 24 24" aria-hidden="true"
          ><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg
        >
        <span class="theme-toggle-label">主题</span>
      </button>
      <button
        class="menu-toggle"
        type="button"
        data-menu-toggle
        aria-label="打开导航菜单"
        aria-controls="primary-navigation"
        aria-expanded="false"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-scroll-header]');
  const compactAt = 12;
  let isCompact = window.scrollY > compactAt;

  const updateHeader = () => {
    const nextCompact = window.scrollY > compactAt;

    if (nextCompact !== isCompact) {
      isCompact = nextCompact;
      header?.classList.toggle('is-compact', isCompact);
    }
  };

  header?.classList.toggle('is-compact', isCompact);
  updateHeader();
  window.addEventListener('scroll', updateHeader, { passive: true });

  const themeToggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const updateThemeToggle = () => {
    const setting = document.documentElement.dataset.themeSetting || 'system';
    let label = '切换主题 (当前：跟随系统)';
    if (setting === 'light') label = '切换主题 (当前：亮色模式)';
    if (setting === 'dark') label = '切换主题 (当前：暗色模式)';
    themeToggle?.setAttribute('aria-label', label);
  };

  themeToggle?.addEventListener('click', () => {
    const currentSetting = document.documentElement.dataset.themeSetting || 'system';
    const currentTheme = document.documentElement.dataset.theme; // actual visual theme ('light' or 'dark')
    
    let nextSetting = 'system';
    if (currentSetting === 'system') {
      // If currently following system, clicking should switch to the OPPOSITE of what's currently shown
      nextSetting = currentTheme === 'dark' ? 'light' : 'dark';
    } else if (currentSetting === 'light') {
      nextSetting = 'dark';
    } else {
      nextSetting = 'system';
    }
    
    if (nextSetting === 'system') {
      localStorage.setItem('theme', 'system');
    } else {
      localStorage.setItem('theme', nextSetting);
    }
    
    // Call the applyTheme function exposed by BaseHead.astro
    if (window.applyTheme) {
      window.applyTheme();
    }
    updateThemeToggle();
  });

  updateThemeToggle();

  const menuToggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const primaryNavigation = document.querySelector<HTMLElement>('#primary-navigation');

  const setMenuOpen = (open: boolean) => {
    header?.classList.toggle('is-menu-open', open);
    menuToggle?.setAttribute('aria-expanded', String(open));
    menuToggle?.setAttribute('aria-label', open ? '关闭导航菜单' : '打开导航菜单');
  };

  menuToggle?.addEventListener('click', () => {
    setMenuOpen(!header?.classList.contains('is-menu-open'));
  });

  primaryNavigation?.addEventListener('click', (event) => {
    if ((event.target as Element).closest('a, .global-search-trigger')) setMenuOpen(false);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setMenuOpen(false);
  });

  window.matchMedia('(min-width: 40.01rem)').addEventListener('change', (event) => {
    if (event.matches) setMenuOpen(false);
  });
</script>

<style>
  .site-header {
    position: relative;
    z-index: 50;
    top: 0;
    width: 100%;
    min-height: var(--header-height);
    pointer-events: none;
  }

  .header-surface {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    width: 100%;
    margin-inline: auto;
    min-height: var(--header-height);
    overflow: hidden;
    border: 1px solid transparent;
    background:
      radial-gradient(ellipse 42rem 29rem at 8% -8rem, rgb(25 200 185 / 19%), transparent 74%),
      radial-gradient(ellipse 34rem 24rem at 92% 9rem, rgb(247 205 103 / 12%), transparent 76%),
      rgb(248 248 240 / 64%);
    box-shadow: none;
    backdrop-filter: blur(14px) saturate(1.06);
    pointer-events: auto;
    isolation: isolate;
    transition:
      width 360ms var(--motion-easing),
      transform 360ms var(--motion-easing),
      border-radius 360ms var(--motion-easing),
      background 360ms var(--motion-easing),
      box-shadow 360ms var(--motion-easing),
      border-color 360ms var(--motion-easing);
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    width: 100%;
    min-height: var(--header-height);
    align-items: center;
    gap: 0;
    padding: 0.5rem clamp(1rem, 5vw, 5rem);
    transition: padding 360ms var(--motion-easing);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-text);
    justify-self: start;
    text-decoration: none;
  }

  .brand-mark {
    display: block;
    width: 2.5rem;
    height: 2.5rem;
    overflow: hidden;
    border-radius: 50%;
    transition: transform 360ms var(--motion-easing);
  }

  .brand-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-copy {
    display: grid;
    gap: 0.05rem;
    line-height: 1;
  }

  .brand-copy strong {
    font-size: 1.12rem;
    font-weight: 900;
    letter-spacing: -0.025em;
  }

  .brand-copy small {
    color: var(--color-text-muted);
    font-size: 0.54rem;
    font-weight: 900;
    letter-spacing: 0.14em;
  }

  ul {
    display: flex;
    flex-wrap: wrap;
    gap: 0.22rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .primary-navigation {
    display: flex;
    align-items: center;
    justify-self: center;
  }

  .menu-toggle {
    display: none;
  }

  nav a {
    display: inline-flex;
    min-height: 2.45rem;
    align-items: center;
    border-radius: var(--radius-pill);
    padding: 0.42rem 0.88rem;
    color: var(--color-text-body);
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    transition:
      background var(--motion-duration) var(--motion-easing),
      color var(--motion-duration) var(--motion-easing),
      transform var(--motion-duration) var(--motion-easing),
      box-shadow var(--motion-duration) var(--motion-easing);
  }

  nav a:hover {
    transform: translateY(-1px);
    background: rgb(25 200 185 / 12%);
    color: var(--color-text);
  }

  nav a[aria-current='page'] {
    background: linear-gradient(135deg, #a9b9dc, #92a8d7);
    box-shadow:
      inset 0 1px rgb(255 255 255 / 34%),
      0 0.16rem 0 #778cb9;
    color: #fff;
  }

  .theme-toggle {
    display: inline-flex;
    min-width: 2.45rem;
    min-height: 2.45rem;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    border: 1px solid transparent;
    border-radius: var(--radius-pill);
    background: transparent;
    color: var(--color-text-body);
    font: inherit;
    font-size: 0.76rem;
    font-weight: 800;
    cursor: pointer;
    justify-self: end;
    transition:
      background var(--motion-duration) var(--motion-easing),
      color var(--motion-duration) var(--motion-easing);
  }

  .theme-toggle:hover {
    background: rgb(25 200 185 / 12%);
    color: var(--color-text);
  }

  .theme-icon {
    width: 1.05rem;
    height: 1.05rem;
    fill: none;
    stroke: currentcolor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.9;
  }

  .theme-icon-moon,
  .theme-icon-system {
    display: none;
  }
  
  :global(:root[data-theme-setting='light']) .theme-icon-sun {
    display: block;
  }
  :global(:root[data-theme-setting='light']) .theme-icon-moon,
  :global(:root[data-theme-setting='light']) .theme-icon-system {
    display: none;
  }

  :global(:root[data-theme-setting='dark']) .theme-icon-sun,
  :global(:root[data-theme-setting='dark']) .theme-icon-system {
    display: none;
  }
  :global(:root[data-theme-setting='dark']) .theme-icon-moon {
    display: block;
  }

  :global(:root[data-theme-setting='system']) .theme-icon-sun,
  :global(:root[data-theme-setting='system']) .theme-icon-moon {
    display: none;
  }
  :global(:root[data-theme-setting='system']) .theme-icon-system {
    display: block;
  }

  .site-header.is-compact .header-surface {
    width: min(calc(100% - (var(--page-gutter) * 2)), var(--header-width));
    border-color: rgb(159 146 125 / 45%);
    border-radius: 1.7rem;
    background:
      linear-gradient(
        112deg,
        rgb(255 255 255 / 88%),
        rgb(247 243 223 / 92%) 48%,
        rgb(240 232 216 / 90%)
      ),
      var(--color-surface-content);
    box-shadow:
      0 1.1rem 2.8rem rgb(61 52 40 / 15%),
      inset 0 1px rgb(255 255 255 / 82%);
    transform: translateY(var(--header-offset));
  }

  :global(:root[data-theme='dark']) .header-surface {
    background:
      radial-gradient(ellipse 42rem 29rem at 8% -8rem, rgb(66 188 169 / 15%), transparent 74%),
      radial-gradient(ellipse 34rem 24rem at 92% 9rem, rgb(231 189 99 / 8%), transparent 76%),
      var(--color-surface-glass);
  }

  :global(:root[data-theme='dark']) .site-header.is-compact .header-surface {
    border-color: rgb(118 139 119 / 52%);
    background: linear-gradient(112deg, rgb(37 47 39 / 94%), rgb(28 36 30 / 95%));
    box-shadow:
      0 1.1rem 2.8rem rgb(0 0 0 / 32%),
      inset 0 1px rgb(255 248 232 / 6%);
  }

  :global(:root[data-theme='dark']) nav a[aria-current='page'] {
    background: linear-gradient(135deg, #49617e, #3f5571);
    box-shadow:
      inset 0 1px rgb(255 248 232 / 16%),
      0 0.16rem 0 #2f4055;
    color: var(--color-white);
  }

  .site-header.is-compact .header-surface::before {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-image: radial-gradient(rgb(121 79 39 / 13%) 1px, transparent 1px);
    background-size: 13px 13px;
    opacity: 0.35;
    content: '';
  }

  .site-header.is-compact .header-inner {
    position: relative;
    z-index: 1;
  }

  .site-header.is-compact .header-inner {
    padding: 0.38rem 0.6rem 0.38rem 0.48rem;
  }

  .site-header.is-compact .brand-mark {
    transform: scale(0.96) rotate(-2deg);
  }

  :global(body[data-header-overlay]) .site-header:not(.is-compact) .header-surface {
    background: linear-gradient(180deg, rgb(20 54 43 / 35%), transparent);
    backdrop-filter: none;
  }

  :global(body[data-header-overlay]) .site-header:not(.is-compact) .brand,
  :global(body[data-header-overlay]) .site-header:not(.is-compact) nav a,
  :global(body[data-header-overlay]) .site-header:not(.is-compact) .theme-toggle,
  :global(body[data-header-overlay]) .site-header:not(.is-compact) .menu-toggle {
    color: #fff;
    text-shadow: 0 0.12rem 0.75rem rgb(27 55 43 / 44%);
  }

  :global(body[data-header-overlay]) .site-header:not(.is-compact) .brand-copy small {
    color: #fff;
  }

  :global(body[data-header-overlay]) .site-header:not(.is-compact) nav a:hover {
    background: rgb(255 255 255 / 15%);
    color: #fff;
  }

  :global(body[data-header-overlay]) .site-header:not(.is-compact) .theme-toggle:hover {
    background: rgb(255 255 255 / 15%);
    color: #fff;
  }

  :global(body[data-header-overlay]) .site-header:not(.is-compact) nav a[aria-current='page'] {
    background: rgb(255 255 255 / 20%);
    box-shadow:
      inset 0 1px rgb(255 255 255 / 32%),
      0 0.16rem 0 rgb(27 55 43 / 24%);
  }

  @media (max-width: 40rem) {
    .header-surface {
      overflow: visible;
    }

    .header-inner {
      display: flex;
      gap: 0;
      padding-inline: 0.5rem;
    }

    .site-header.is-compact .header-surface {
      width: calc(100% - (var(--page-gutter) * 2));
      transform: translateY(0.5rem);
    }

    .primary-navigation {
      position: absolute;
      top: calc(100% + 0.45rem);
      left: 50%;
      z-index: 2;
      display: none;
      width: 100vw;
      transform: translateX(-50%);
      border: 1px solid rgb(159 146 125 / 48%);
      border-radius: var(--radius-large);
      background: var(--color-surface-content);
      padding: 0.7rem;
      box-shadow: var(--shadow-base);
    }

    .site-header.is-menu-open .primary-navigation {
      display: grid;
      gap: 0.35rem;
    }

    .primary-navigation nav {
      min-width: 0;
      overflow: visible;
    }

    .primary-navigation ul {
      display: grid;
      gap: 0.35rem;
    }

    .primary-navigation nav a {
      width: 100%;
      min-height: 3.1rem;
      justify-content: flex-start;
      padding-inline: 1rem;
      font-size: 0.96rem;
    }

    .brand {
      margin-right: auto;
    }

    .brand-copy {
      display: grid;
      max-width: min(40vw, 9rem);
    }

    .brand-copy small {
      display: none;
    }

    .brand-copy strong {
      overflow: hidden;
      font-size: 1rem;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .brand-mark {
      width: 2.25rem;
      height: 2.25rem;
    }

    .theme-toggle {
      min-width: 2.25rem;
      min-height: 2.25rem;
      margin-left: 0.15rem;
    }

    .menu-toggle {
      display: grid;
      width: 2.75rem;
      min-width: 2.75rem;
      height: 2.75rem;
      align-content: center;
      justify-content: center;
      gap: 0.24rem;
      margin-left: 0.15rem;
      border: 1px solid transparent;
      border-radius: var(--radius-pill);
      background: transparent;
      color: var(--color-text-body);
      cursor: pointer;
    }

    .menu-toggle span {
      display: block;
      width: 1.15rem;
      height: 0.14rem;
      border-radius: var(--radius-pill);
      background: currentcolor;
      transition: transform var(--motion-duration) var(--motion-easing);
    }

    .site-header.is-menu-open .menu-toggle span:nth-child(1) {
      transform: translateY(0.4rem) rotate(45deg);
    }

    .site-header.is-menu-open .menu-toggle span:nth-child(2) {
      transform: scaleX(0);
    }

    .site-header.is-menu-open .menu-toggle span:nth-child(3) {
      transform: translateY(-0.4rem) rotate(-45deg);
    }

    .theme-toggle-label {
      display: none;
    }
  }
</style>
