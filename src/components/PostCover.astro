---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type CoverTone = 'mint' | 'sunset' | 'ocean' | 'plum' | 'forest';

interface Props {
  title: string;
  category?: string | undefined;
  tags?: string[] | undefined;
  tone: CoverTone;
  label?: string | undefined;
  image?: ImageMetadata | undefined;
  imageUrl?: string | undefined;
  alt?: string | undefined;
  priority?: boolean | undefined;
  size?: 'card' | 'feature' | 'article' | undefined;
  decorative?: boolean | undefined;
}

const {
  title,
  category,
  tags = [],
  tone,
  label = category ?? 'ACORN FIELD NOTE',
  image,
  imageUrl,
  alt = `${title} 的文章封面`,
  priority = false,
  size = 'card',
  decorative = false,
} = Astro.props;
---

<div class:list={['post-cover', `size-${size}`]} data-tone={tone}>
  {
    image ? (
      <Image
        src={image}
        alt={alt}
        width={1000}
        height={500}
        loading={priority ? 'eager' : 'lazy'}
      />
    ) : imageUrl ? (
      <img src={imageUrl} alt={alt} loading={priority ? 'eager' : 'lazy'} />
    ) : (
      <div class="generated-cover" role="img" aria-label={alt}>
        <div class="cover-sun" aria-hidden="true" />
        <div class="cover-hills hill-back" aria-hidden="true" />
        <div class="cover-hills hill-front" aria-hidden="true" />
        {!decorative && (
          <div class="cover-copy">
            <span class="cover-label">{label}</span>
            <strong>{title}</strong>
            {tags[0] && <span class="cover-tag">#{tags[0]}</span>}
          </div>
        )}
      </div>
    )
  }
</div>

<style>
  .post-cover {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    aspect-ratio: 2 / 1;
    border: 2px solid rgb(255 255 255 / 58%);
    border-radius: calc(var(--radius-large) - 0.25rem);
    background: #a4daca;
  }

  .post-cover :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .generated-cover {
    position: absolute;
    inset: 0;
    overflow: hidden;
    background: linear-gradient(145deg, var(--cover-sky-start), var(--cover-sky-end));
    color: var(--cover-text);
  }

  .generated-cover::before,
  .generated-cover::after {
    position: absolute;
    border-radius: 999px;
    background: rgb(255 255 255 / 12%);
    content: '';
  }

  .generated-cover::before {
    width: 32%;
    aspect-ratio: 1;
    top: -16%;
    right: 9%;
  }

  .generated-cover::after {
    width: 48%;
    aspect-ratio: 1;
    bottom: -38%;
    left: -12%;
  }

  .cover-sun {
    position: absolute;
    top: 13%;
    right: 13%;
    width: 17%;
    aspect-ratio: 1;
    border: 5px solid rgb(255 255 255 / 28%);
    border-radius: 50%;
    background: var(--cover-sun);
    box-shadow: 0 0 0 0.6rem rgb(255 255 255 / 8%);
  }

  .cover-hills {
    position: absolute;
    right: -8%;
    left: -8%;
    border-radius: 50% 50% 0 0 / 32% 32% 0 0;
  }

  .hill-back {
    bottom: -19%;
    height: 58%;
    background: var(--cover-hill-back);
    transform: rotate(-4deg);
  }

  .hill-front {
    bottom: -33%;
    height: 63%;
    background: var(--cover-hill-front);
    transform: rotate(4deg);
  }

  .cover-copy {
    position: absolute;
    z-index: 2;
    top: 12%;
    left: 8%;
    display: grid;
    max-width: 55%;
    gap: 0.45rem;
  }

  .cover-label,
  .cover-tag {
    width: fit-content;
    border: 1px solid rgb(255 255 255 / 38%);
    border-radius: var(--radius-pill);
    background: rgb(255 255 255 / 14%);
    padding: 0.22rem 0.55rem;
    color: inherit;
    font-size: clamp(0.55rem, 1vw, 0.75rem);
    font-weight: 900;
    letter-spacing: 0.1em;
  }

  strong {
    color: inherit;
    font-size: clamp(1.2rem, 3vw, 2.65rem);
    font-weight: 900;
    letter-spacing: 0.01em;
    line-height: 1.1;
    text-wrap: balance;
  }

  .cover-tag {
    border: 0;
    background: transparent;
    padding-inline: 0;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .size-feature .cover-copy {
    top: 14%;
    left: 7%;
  }

  .size-article {
    border-radius: var(--radius-large);
  }

  [data-tone='mint'] {
    --cover-sky-start: #70cfb7;
    --cover-sky-end: #c9f1d7;
    --cover-sun: #f8da76;
    --cover-hill-back: #4eaa85;
    --cover-hill-front: #248468;
    --cover-text: #fffaf0;
  }

  [data-tone='sunset'] {
    --cover-sky-start: #f19b74;
    --cover-sky-end: #ffddb0;
    --cover-sun: #f8cf62;
    --cover-hill-back: #ce725b;
    --cover-hill-front: #9e4c4b;
    --cover-text: #fff9ec;
  }

  [data-tone='ocean'] {
    --cover-sky-start: #789fe1;
    --cover-sky-end: #c9e0f8;
    --cover-sun: #f5d873;
    --cover-hill-back: #4d82bf;
    --cover-hill-front: #356b9c;
    --cover-text: #fffaf0;
  }

  [data-tone='plum'] {
    --cover-sky-start: #a97ad7;
    --cover-sky-end: #e9c6f0;
    --cover-sun: #f4d468;
    --cover-hill-back: #8056ad;
    --cover-hill-front: #5d397e;
    --cover-text: #fffaf0;
  }

  [data-tone='forest'] {
    --cover-sky-start: #7eae79;
    --cover-sky-end: #dae6aa;
    --cover-sun: #f1d064;
    --cover-hill-back: #527b4e;
    --cover-hill-front: #385c3a;
    --cover-text: #fffaf0;
  }

  @media (max-width: 34rem) {
    .cover-copy {
      max-width: 65%;
    }
  }
</style>
