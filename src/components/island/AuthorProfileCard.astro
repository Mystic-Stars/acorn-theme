---
import { Card } from '@components/animal';
import { homeConfig, siteConfig } from '@config/index';

const { author } = siteConfig;
const { sidebar } = homeConfig;
---

<Card className="sidebar-card author-profile-card">
  <div class="author-flip-container" data-author-profile>
    <div class="author-flipper">
      <!-- 正面 -->
      <div class="author-front">
        <div class="author-summary">
          <span class="author-avatar" aria-hidden="true">
            <img src={siteConfig.branding.avatarSrc} alt="" />
          </span>
          <div class="author-identity">
            <small>{sidebar.authorEyebrow}</small>
            <strong>{author.name}</strong>
            <span>{author.role}</span>
          </div>
        </div>

        <p class="author-bio">{author.bio}</p>

        <button
          class="author-flip-trigger"
          type="button"
          aria-expanded="false"
          aria-controls="author-profile-details"
          data-author-toggle
        >
          {sidebar.authorToggleLabel}
          <span class="author-chevron" aria-hidden="true">→</span>
        </button>
      </div>

      <!-- 背面 -->
      <div
        class="author-back"
        id="author-profile-details"
        aria-hidden="true"
        data-author-details
        inert
      >
        <dl>
          <div>
            <dt>坐标</dt>
            <dd>{author.location}</dd>
          </div>
          <div>
            <dt>关注</dt>
            <dd>{author.focus.join(' · ')}</dd>
          </div>
        </dl>
        <blockquote>“{author.motto}”</blockquote>

        <div class="author-back-footer">
          <a href="/about/">{sidebar.authorLinkLabel}<span aria-hidden="true">→</span></a>
          <button class="author-flip-trigger-back" type="button" data-author-toggle>
            {sidebar.authorCollapseLabel}
          </button>
        </div>
      </div>
    </div>
  </div>
</Card>

<script is:inline>
  for (const container of document.querySelectorAll('[data-author-profile]')) {
    const toggles = container.querySelectorAll('[data-author-toggle]');
    const details = container.querySelector('[data-author-details]');

    for (const toggle of toggles) {
      toggle.addEventListener('click', (e) => {
        e.preventDefault();
        const expanded = container.classList.contains('is-flipped');
        container.classList.toggle('is-flipped', !expanded);
        if (details instanceof HTMLElement) {
          details.setAttribute('aria-hidden', String(expanded));
          details.inert = expanded;
        }
      });
    }
  }
</script>

<style>
  :global(.author-profile-card) {
    overflow: visible;
    padding: 0 !important;
    perspective: 1200px;
  }

  .author-flip-container {
    width: 100%;
    height: 100%;
  }

  .author-flipper {
    position: relative;
    width: 100%;
    height: 100%;
    transition: transform 600ms cubic-bezier(0.34, 1.56, 0.64, 1);
    transform-style: preserve-3d;
  }

  .author-flip-container:hover .author-flipper,
  .author-flip-container.is-flipped .author-flipper {
    transform: rotateY(180deg);
  }

  .author-front,
  .author-back {
    width: 100%;
    backface-visibility: hidden;
    padding: 1.05rem;
    display: flex;
    flex-direction: column;
    background: transparent;
  }

  .author-back {
    position: absolute;
    top: 0;
    left: 0;
    height: 100%;
    transform: rotateY(180deg);
  }

  /* --- 正面样式 --- */
  .author-summary {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    position: relative;
    display: block;
    width: 3.55rem;
    height: 3.55rem;
    border: 3px solid #fffaf0;
    border-radius: 50%;
    overflow: hidden;
    transform: rotate(-3deg);
    transition:
      transform 420ms var(--motion-easing),
      border-radius 420ms var(--motion-easing);
  }

  .author-avatar img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .author-flip-container:hover .author-avatar,
  .author-flip-container.is-flipped .author-avatar {
    border-radius: 50%;
    transform: translateY(-0.18rem) rotate(3deg);
  }

  .author-identity {
    display: flex;
    min-width: 0;
    flex-direction: column;
    line-height: 1.25;
  }

  .author-identity small {
    color: #c08756;
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .author-identity strong {
    margin-top: 0.18rem;
    color: var(--color-text);
    font-size: 1.05rem;
  }

  .author-identity > span {
    margin-top: 0.18rem;
    color: var(--color-text-muted);
    font-size: 0.72rem;
    font-weight: 700;
  }

  .author-bio {
    flex: 1;
    margin: 0.9rem 0 0;
    color: var(--color-text-body);
    font-size: 0.82rem;
    line-height: 1.65;
  }

  .author-flip-trigger {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    border: none;
    background: transparent;
    padding: 0;
    color: var(--color-text-muted);
    font-size: 0.64rem;
    font-weight: 700;
    cursor: pointer;
  }

  .author-chevron {
    display: grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 50%;
    background: rgb(192 135 86 / 15%);
    color: #c08756;
    transition:
      transform var(--motion-duration) var(--motion-easing),
      background var(--motion-duration) var(--motion-easing);
  }

  .author-flip-trigger:hover .author-chevron {
    background: rgb(192 135 86 / 25%);
    transform: translateX(0.15rem);
  }

  /* --- 背面样式 --- */
  dl {
    display: grid;
    gap: 0.45rem;
    margin: 0;
    padding-top: 0.5rem;
    border-top: 1px dashed rgb(192 135 86 / 28%);
  }

  dl div {
    display: grid;
    grid-template-columns: 4.2rem minmax(0, 1fr);
    gap: 0.5rem;
  }

  dt {
    color: var(--color-text-muted);
    font-size: 0.7rem;
  }

  dd {
    margin: 0;
    color: var(--color-text);
    font-size: 0.74rem;
    font-weight: 800;
    text-align: right;
  }

  blockquote {
    flex: 1;
    margin: 0.75rem 0;
    border-radius: var(--radius-small);
    background: rgb(255 255 255 / 46%);
    padding: 0.55rem 0.7rem;
    color: var(--color-text-body);
    font-size: 0.76rem;
    font-weight: 700;
  }

  .author-back-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
  }

  .author-back-footer a {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: #b37042;
    font-size: 0.8rem;
    font-weight: 900;
    text-decoration: none;
  }

  .author-back-footer a span {
    transition: transform var(--motion-duration) var(--motion-easing);
  }

  .author-back-footer a:hover span {
    transform: translateX(0.22rem);
  }

  .author-flip-trigger-back {
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    padding: 0;
    font-size: 0.64rem;
    font-weight: 700;
    cursor: pointer;
  }

  .author-flip-trigger-back:hover {
    color: var(--color-text);
  }
</style>
