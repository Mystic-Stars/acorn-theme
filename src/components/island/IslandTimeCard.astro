---
import { Card, Time } from '@components/animal';
---

<Card className="sidebar-card island-time-card">
  <section aria-label="当前本地时间">
    <Time client:only="react" className="island-time" />
  </section>
</Card>

<style>
  :global(.island-time-card) {
    padding: 0.75rem !important;
  }

  :global(.island-time-card:hover) {
    transform: none !important;
  }

  section {
    display: flex;
    justify-content: center;
  }

  section :global(.island-time) {
    max-width: 100%;
  }
</style>
