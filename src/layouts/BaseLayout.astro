---
import BaseHead from '@components/BaseHead.astro';
import Analytics from '@components/Analytics.astro';
import Footer from '@components/Footer.astro';
import Header from '@components/Header.astro';
import { siteConfig, themeInlineStyle } from '@config/index';
import type { ImageMetadata } from 'astro';
import 'animal-island-ui/style';
import '@styles/twikoo-island.css';

interface Props {
  title?: string | undefined;
  description?: string | undefined;
  image?: ImageMetadata | string | undefined;
  type?: 'website' | 'article' | undefined;
  noindex?: boolean | undefined;
  headerOverlay?: boolean | undefined;
  // Article specific props
  pubDate?: Date | undefined;
  updatedDate?: Date | undefined;
  author?: string | undefined;
  tags?: string[] | undefined;
  // Pagination props
  prevUrl?: string | URL | undefined;
  nextUrl?: string | URL | undefined;
}

const {
  title,
  description,
  image,
  type,
  noindex,
  headerOverlay = false,
  pubDate,
  updatedDate,
  author,
  tags,
  prevUrl,
  nextUrl,
} = Astro.props;
---

<!doctype html>
<html lang={siteConfig.language} style={themeInlineStyle}>
  <head>
    <BaseHead
      {title}
      {description}
      {image}
      {type}
      {noindex}
      {pubDate}
      {updatedDate}
      {author}
      {tags}
      {prevUrl}
      {nextUrl}
    />
    <Analytics />
  </head>
  <body data-header-overlay={headerOverlay || undefined}>
    <a class="skip-link" href="#main-content">跳到正文</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>
