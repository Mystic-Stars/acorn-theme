---
import FormattedDate from '@components/FormattedDate.astro';
import PostCover from '@components/PostCover.astro';
import TagList from '@components/TagList.astro';
import { Card, Divider, Title } from '@components/animal';
import AuthorProfileCard from '@components/island/AuthorProfileCard.astro';
import TwikooComments from '@components/island/TwikooComments.astro';
import IslandStatusCard from '@components/island/IslandStatusCard.astro';
import IslandTimeCard from '@components/island/IslandTimeCard.astro';
import TagExplorerCard from '@components/island/TagExplorerCard.astro';
import ArticleTableOfContents from '@components/island/ArticleTableOfContents.astro';
import ArticleReaderEnhancements from '@components/island/ArticleReaderEnhancements.astro';
import ArticleViewCount from '@components/island/ArticleViewCount.astro';
import MarkdownTableEnhancer from '@components/react/MarkdownTableEnhancer';
import { archiveConfig, siteConfig } from '@config/index';
import { getBlogStats } from '@lib/blog-stats';
import type { BlogPost } from '@lib/posts';
import { collectTags, getPostHref, getPublishedPosts } from '@lib/posts';
import BaseLayout from './BaseLayout.astro';

interface Props {
  post: BlogPost;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { post, headings } = Astro.props;
const { title, description, pubDate, updatedDate, cover, tags, author, category } = post.data;
const posts = await getPublishedPosts();
const allTags = collectTags(posts);
const blogStats = getBlogStats(posts, siteConfig.establishedAt);
const hasMarkdownTable =
  /^[^\n]*\|[^\n]*\n\s*\|?\s*:?-{3,}:?\s*(?:\|\s*:?-{3,}:?\s*)+\|?\s*$/m.test(post.body ?? '');
---

<BaseLayout
  image={cover.image ?? cover.url}
  {title}
  {description}
  type="article"
  {pubDate}
  {updatedDate}
  {author}
  {tags}
  headerOverlay
>
  <article class="article">
    <header class="article-hero">
      <div class="hero-backdrop" aria-hidden="true">
        <PostCover
          {title}
          {category}
          {tags}
          tone={cover.tone}
          label={cover.label}
          image={cover.image}
          imageUrl={cover.url}
          alt=""
          priority
          size="article"
          decorative
        />
      </div>

      <div class="hero-scrim" aria-hidden="true"></div>

      <div class="hero-inner container">
        <div class="hero-copy">
          {
            category && (
              <Title size="small" color="app-yellow">
                {category}
              </Title>
            )
          }
          <h1>{title}</h1>
          <p class="description">{description}</p>

          <dl class="meta" aria-label="文章信息">
            {
              archiveConfig.showPublishedDate && (
                <div>
                  <dt>发布</dt>
                  <dd>
                    <FormattedDate date={pubDate} />
                  </dd>
                </div>
              )
            }
            <div>
              <dt>作者</dt>
              <dd>{author ?? siteConfig.author.name}</dd>
            </div>
            <div>
              <dt>阅读</dt>
              <dd><ArticleViewCount legacyViews={post.data.legacyViews} /></dd>
            </div>
            {
              archiveConfig.showUpdatedDate && updatedDate && (
                <div>
                  <dt>更新</dt>
                  <dd>
                    <FormattedDate date={updatedDate} />
                  </dd>
                </div>
              )
            }
          </dl>

          {archiveConfig.showTags && tags.length > 0 && <TagList {tags} />}
        </div>

        <div class="hero-cover">
          <PostCover
            {title}
            {category}
            {tags}
            tone={cover.tone}
            label={cover.label}
            image={cover.image}
            imageUrl={cover.url}
            alt={cover.alt}
            priority
            size="article"
          />
        </div>
      </div>
    </header>

    <div class="article-content container">
      <section class="article-main" aria-label="文章正文">
        <div class="article-divider" aria-hidden="true"><Divider type="wave-yellow" /></div>
        <Card className="article-card" pattern="default">
          <div class="prose">
            <slot />
          </div>
          {hasMarkdownTable && <MarkdownTableEnhancer client:load />}
          <ArticleReaderEnhancements />
        </Card>
        <TwikooComments path={getPostHref(post)} />
      </section>

      <aside class="sidebar" aria-label="博客小组件">
        <ArticleTableOfContents {headings} />
        <AuthorProfileCard />
        <IslandTimeCard />
        <IslandStatusCard stats={blogStats} />
        <TagExplorerCard tags={allTags} />
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    overflow: clip;
  }

  .article-hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(30rem, 42vw, 34rem);
    overflow: hidden;
    margin-top: calc(-1 * var(--header-height));
    padding-block: calc(var(--header-height) + clamp(1.5rem, 4vw, 3rem)) clamp(1.5rem, 4vw, 3rem);
    background: #000;
  }

  .hero-backdrop,
  .hero-scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-backdrop {
    z-index: -2;
    display: grid;
    place-items: center;
  }

  .hero-backdrop :global(.post-cover) {
    width: 150%;
    height: 150%;
    border: 0;
    /* Organic blob shape for distortion */
    border-radius: 40% 60% 70% 30% / 40% 50% 60% 50%;
    /* Contrast boost and adjusted filters to prevent muddy/burnt colors */
    filter: blur(120px) saturate(1.5) contrast(1.2) brightness(1.1);
    opacity: 0.85;
    transform: scale(1.2) rotate(-15deg) skew(-10deg);
  }

  .hero-backdrop :global(img),
  .hero-backdrop :global(.generated-cover) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-scrim {
    z-index: -1;
    /* Pure black transparent gradients prevent dirty color mixing, fading to 0 opacity */
    background:
      linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.75) 0%,
        rgba(0, 0, 0, 0.35) 55%,
        rgba(0, 0, 0, 0) 100%
      ),
      linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.5) 100%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(17rem, 28rem);
    gap: clamp(1rem, 2vw, 2rem);
    align-items: center;
    min-height: clamp(20rem, 30vw, 24rem);
  }

  .hero-copy {
    max-width: 46rem;
    color: #fff;
  }

  .hero-copy h1 {
    max-width: 25ch;
    margin: 1.35rem 0 1rem;
    color: #fff;
    font-size: clamp(2.2rem, 4.2vw, 4.2rem);
    font-weight: 900;
    letter-spacing: -0.035em;
    line-height: 1.06;
    text-wrap: balance;
    text-shadow: 0 0.18rem 1.8rem rgb(0 0 0 / 45%);
  }

  .description {
    max-width: 42rem;
    margin: 0;
    color: #fff;
    font-size: clamp(1rem, 1.4vw, 1.22rem);
    line-height: 1.85;
    text-wrap: pretty;
  }

  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem 1.75rem;
    margin: 1.65rem 0 1.25rem;
  }

  .meta div {
    display: grid;
    gap: 0.05rem;
  }

  .meta dt {
    color: #fff;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.12em;
  }

  .meta dd {
    margin: 0;
    color: #fff;
    font-size: 0.92rem;
    font-weight: 800;
  }

  .hero-copy :global(ul) {
    justify-content: flex-start;
  }

  .hero-copy :global([class*='animal-tag']) {
    background: rgb(255 255 255 / 16%);
    color: #fff;
  }

  .hero-copy :global([class*='animal-text']) {
    color: #fff;
  }

  .hero-cover {
    width: min(100%, 28rem);
    justify-self: end;
    transform: rotate(2deg);
    border-radius: calc(var(--radius-large) + 0.35rem);
    padding: 0.65rem;
    background: rgb(255 253 246 / 82%);
    box-shadow:
      0 1.35rem 3.7rem rgb(20 18 15 / 34%),
      0 0.25rem 0 rgb(255 255 255 / 28%);
  }

  .hero-cover :global(.post-cover) {
    box-shadow: inset 0 0 0 1px rgb(114 93 66 / 12%);
  }

  .article-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 21rem);
    gap: clamp(1.75rem, 4vw, 4.5rem);
    align-items: start;
    padding-block: clamp(2.5rem, 7vw, 5.5rem) clamp(4rem, 8vw, 7rem);
  }

  .article-main {
    min-width: 0;
  }

  .sidebar {
    position: sticky;
    top: calc(var(--header-offset) + var(--header-height) + 1rem);
    display: grid;
    gap: 1rem;
  }

  .sidebar :global(.sidebar-card) {
    padding: 1.15rem;
  }

  .article-divider {
    margin: 0 0 1.35rem;
  }

  .article-content :global(.article-card) {
    overflow: hidden;
    padding: 0;
  }

  .article-content :global(.article-card:hover) {
    transform: none !important;
  }

  .prose {
    padding: clamp(1.4rem, 5vw, 3.6rem);
    color: var(--color-text-body);
    font-size: clamp(1.04rem, 1.2vw, 1.16rem);
    font-weight: 500;
    line-height: 2;
    overflow-wrap: break-word;
  }

  .prose :global(> :first-child) {
    margin-top: 0;
  }

  .prose :global(> :last-child) {
    margin-bottom: 0;
  }

  .prose :global(h2),
  .prose :global(h3),
  .prose :global(h4) {
    scroll-margin-top: calc(var(--header-height) + 1.5rem);
    color: var(--color-text);
    font-weight: 900;
    text-wrap: balance;
  }

  .prose :global(h2) {
    margin: 2.75em 0 0.75em;
    font-size: clamp(1.65rem, 3.5vw, 2.25rem);
  }

  .prose :global(h3) {
    margin: 2.5em 0 0.7em;
    font-size: clamp(1.35rem, 2.6vw, 1.7rem);
  }

  .prose :global(h4) {
    margin: 2.25em 0 0.65em;
    font-size: 1.18rem;
  }

  .prose :global(p),
  .prose :global(ul),
  .prose :global(ol),
  .prose :global(blockquote),
  .prose :global(pre),
  .prose :global(table) {
    margin-block: 0 1.55rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.55em;
  }

  .prose :global(li + li) {
    margin-top: 0.42rem;
  }

  .prose :global(li::marker) {
    color: var(--color-primary-active);
    font-weight: 900;
  }

  .prose :global(a) {
    color: var(--color-primary-active);
    font-weight: 800;
    text-decoration-color: rgb(17 168 155 / 44%);
    text-decoration-thickness: 0.12em;
  }

  .prose :global(a:hover) {
    color: var(--color-text);
    text-decoration-color: currentcolor;
  }

  .prose :global(strong) {
    color: var(--color-text);
    font-weight: 900;
  }

  .prose :global(em) {
    color: #8b663a;
  }

  .prose :global(blockquote) {
    position: relative;
    margin-inline: 0;
    border: 0;
    border-radius: var(--radius-base);
    background: linear-gradient(135deg, rgb(25 200 185 / 13%), rgb(247 205 103 / 13%));
    padding: 1.25rem 1.35rem 1.25rem 1.65rem;
    color: var(--color-text);
    font-size: 1.02em;
    font-weight: 700;
  }

  .prose :global(blockquote::before) {
    position: absolute;
    top: 0.95rem;
    bottom: 0.95rem;
    left: 0.65rem;
    width: 0.26rem;
    border-radius: var(--radius-pill);
    background: var(--color-primary);
    content: '';
  }

  .prose :global(blockquote > :last-child) {
    margin-bottom: 0;
  }

  .prose :global(:not(pre) > code) {
    border: 1px solid rgb(159 146 125 / 28%);
    border-radius: 0.45rem;
    background: #f0e8d8;
    padding: 0.14em 0.42em;
    color: #80522c;
    font-size: 0.84em;
    font-weight: 800;
  }

  .prose :global(hr) {
    height: 0;
    margin: 2.7rem 0;
    border: 0;
    border-top: 2px dashed rgb(159 146 125 / 44%);
  }

  .prose :global(table:not(.article-animal-table)) {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-spacing: 0;
    border: 1px solid rgb(159 146 125 / 35%);
    border-radius: var(--radius-base);
    background: rgb(255 255 255 / 35%);
  }

  .prose :global(table:not(.article-animal-table) th),
  .prose :global(table:not(.article-animal-table) td) {
    min-width: 8rem;
    padding: 0.75rem 0.9rem;
    border-bottom: 1px dashed rgb(159 146 125 / 32%);
    text-align: left;
  }

  .prose :global(table:not(.article-animal-table) th) {
    background: rgb(247 205 103 / 16%);
    color: var(--color-text);
    font-weight: 900;
  }

  .prose :global(table:not(.article-animal-table) tr:last-child td) {
    border-bottom: 0;
  }

  .prose :global(img) {
    margin-block: 2rem;
    border-radius: var(--radius-base);
  }

  @media (max-width: 48rem) {
    .article-hero {
      min-height: auto;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .hero-cover {
      width: min(100%, 34rem);
      justify-self: start;
      transform: rotate(1deg);
    }

    .article-content {
      grid-template-columns: 1fr;
    }

    .sidebar {
      position: static;
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 32rem) {
    .article-hero {
      padding-block: calc(var(--header-height) + 2rem) 2.35rem;
    }

    .hero-copy h1 {
      font-size: clamp(1.8rem, 10vw, 2.8rem);
    }

    .hero-cover {
      padding: 0.45rem;
    }

    .prose {
      line-height: 1.9;
    }

    .sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>
