---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { friendLinksConfig } from '@config/index';
import { siteConfig } from '@config/site';
import { CodeBlock } from 'animal-island-ui';

const allFriends = await getCollection('friends');
const friends = allFriends
  // Hide both explicit private entries and underscore-prefixed repository templates.
  .filter((friend) => !friend.data.hidden && !friend.id.split('/').some((part) => part.startsWith('_')))
  .sort((left, right) => {
    if (left.data.featured !== right.data.featured) return left.data.featured ? -1 : 1;
    return Math.random() - 0.5;
  });
const categoriesWithFriends = friendLinksConfig.categories.map((category) => ({
  name: category,
  count: friends.filter((friend) => friend.data.category === category).length,
}));
const latestSubmission = friends
  .map((friend) => friend.data.submittedAt)
  .filter((date): date is Date => Boolean(date))
  .sort((left, right) => right.getTime() - left.getTime())[0];
const submittedLabel = latestSubmission
  ? new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'short', day: 'numeric' }).format(
      latestSubmission,
    )
  : '等待第一位朋友';
---

<BaseLayout title={friendLinksConfig.title} description={friendLinksConfig.description}>
  <section
    class="friends-page"
    data-friends-page
    data-repository={friendLinksConfig.repository}
    data-branch={friendLinksConfig.defaultBranch}
    data-directory={friendLinksConfig.contentDirectory}
  >
    <header class="friends-hero">
      <div class="hero-copy">
        <p class="eyebrow"><span aria-hidden="true">✦</span> NEIGHBORHOOD BOARD</p>
        <h1>{friendLinksConfig.title}</h1>
        <p>{friendLinksConfig.description}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#submit-friend">投递我的小岛 <span aria-hidden="true">→</span></a>
          <a
            class="button button-quiet"
            href={`https://github.com/${friendLinksConfig.repository}/pulls`}
            target="_blank"
            rel="noreferrer"
          >
            查看申请进度
          </a>
        </div>
      </div>
      <dl class="island-stats" aria-label="友链统计">
        <div>
          <dt>已落户</dt>
          <dd>{friends.length}</dd>
        </div>
        <div>
          <dt>分类</dt>
          <dd>{categoriesWithFriends.filter((category) => category.count > 0).length}</dd>
        </div>
        <div>
          <dt>最新投递</dt>
          <dd class="latest-date">{submittedLabel}</dd>
        </div>
      </dl>
      <div class="hero-decoration hero-decoration-leaf" aria-hidden="true">⌁</div>
      <div class="hero-decoration hero-decoration-star" aria-hidden="true">✦</div>
    </header>

    <section class="friend-directory" aria-labelledby="directory-title">
      <div class="section-heading">
        <div>
          <p class="eyebrow">ISLAND DIRECTORY</p>
          <h2 id="directory-title">岛民名册</h2>
        </div>
        <label class="friend-search">
          <span class="sr-only">搜索友链</span>
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="10.8" cy="10.8" r="6.2"></circle><path d="m16 16 4.2 4.2"></path></svg>
          <input type="search" data-friend-search placeholder="搜索名字、简介或标签" autocomplete="off" />
        </label>
      </div>

      <div class="directory-controls">
        <div class="category-tabs" role="group" aria-label="友链分类">
          <button class="category-tab is-active" type="button" data-category="all" aria-pressed="true">
            全部 <span>{friends.length}</span>
          </button>
          {
            categoriesWithFriends
              .filter((category) => category.count > 0)
              .map((category) => (
                <button class="category-tab" type="button" data-category={category.name} aria-pressed="false">
                  {category.name} <span>{category.count}</span>
                </button>
              ))
          }
        </div>
        <p class="result-count" data-result-count>共 {friends.length} 位邻居</p>
      </div>

      {
        friends.length ? (
          <div class="friend-grid" data-friend-grid>
            {
              friends.map((friend) => (
                <a
                  class:list={['friend-card', { 'is-featured': friend.data.featured }]}
                  href={friend.data.url}
                  target="_blank"
                  rel="noreferrer"
                  data-friend-card
                  data-category={friend.data.category}
                  data-search={[friend.data.name, friend.data.description, ...friend.data.tags]
                    .join(' ')
                    .toLocaleLowerCase('zh-CN')}
                >
                  {friend.data.featured && (
                    <div class="featured-watermark" aria-hidden="true">
                      <div class="fw-marquee">
                        <span>✦ 特别推荐 ✦ FEATURED ✦ 优质邻居 ✦ FEATURED </span>
                        <span>✦ 特别推荐 ✦ FEATURED ✦ 优质邻居 ✦ FEATURED </span>
                      </div>
                    </div>
                  )}
                  <img class="friend-avatar" src={friend.data.avatar} alt={`${friend.data.name} 的头像`} loading="lazy" />
                  <span class="friend-card-content">
                    <span class="friend-card-topline">
                      <span class="friend-name">{friend.data.name}</span>
                      <svg class="external-arrow" viewBox="0 0 24 24" width="1.1em" height="1.1em" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="7" y1="17" x2="17" y2="7"></line>
                        <polyline points="7 7 17 7 17 17"></polyline>
                      </svg>
                    </span>
                    <span class="friend-description">{friend.data.description}</span>
                    <span class="friend-meta">
                      <span class="category-chip">{friend.data.category}</span>
                      {friend.data.tags.slice(0, 2).map((tag) => <span class="friend-tag">#{tag}</span>)}
                    </span>
                  </span>
                </a>
              ))
            }
          </div>
        ) : (
          <div class="empty-directory">
            <span aria-hidden="true">🌱</span>
            <h3>{friendLinksConfig.emptyState.title}</h3>
            <p>{friendLinksConfig.emptyState.description}</p>
            <a href="#submit-friend">成为第一位邻居 →</a>
          </div>
        )
      }
      <p class="no-results" data-no-results hidden>没有找到匹配的邻居，换个关键词或分类试试。</p>
    </section>

    <section class="join-section" id="submit-friend" aria-labelledby="join-title">
      <div class="join-intro">
        <p class="eyebrow">OPEN CONTRIBUTION</p>
        <h2 id="join-title">一键投递友链</h2>
        <p>填写资料后会跳转到 GitHub，为你创建一份独立的友链文件。确认提交并发起 Pull Request 后，等待站长合并即可。</p>
        <ol class="contribution-steps">
          <li><span>1</span> 填写你的站点资料</li>
          <li><span>2</span> GitHub 自动创建文件（如果提示错误，请先 fork 一份博客源码，然后再次点击创建PR）</li>
          <li><span>3</span> 创建 PR，等待合并</li>
        </ol>
        <div class="site-info-codeblock">
          <p class="site-info-title">本站信息参考</p>
          <div class="code-wrapper">
            <button class="copy-code-btn" type="button" aria-label="复制代码" data-copy-site-info>复制</button>
            <CodeBlock
              code={`name: "${siteConfig.name}"
url: "${Astro.site ?? Astro.url.origin}/"
description: "${siteConfig.description}"
avatar: "${new URL(siteConfig.branding.avatarSrc, Astro.site ?? Astro.url.origin).href}"`}
            />
          </div>
        </div>
      </div>

      <form class="submission-form" data-friend-form novalidate>
        <div class="form-grid">
          <label>
            <span>站点名称 <b>*</b></span>
            <input name="name" required maxlength="40" placeholder="例如：小王的数字花园" autocomplete="organization" />
          </label>
          <label>
            <span>站点地址 <b>*</b></span>
            <input name="url" required type="url" placeholder="https://example.com" inputmode="url" />
          </label>
          <label class="form-wide">
            <span>站点简介 <b>*</b> <em>1–80 字</em></span>
            <textarea name="description" required minlength="1" maxlength="80" rows="3" placeholder="用一两句话介绍你的站点与正在分享的内容。"></textarea>
          </label>
          <label>
            <span>头像地址 <b>*</b></span>
            <input name="avatar" required type="url" placeholder="https://example.com/avatar.png" inputmode="url" />
          </label>
          <label>
            <span>分类 <b>*</b></span>
            <select name="category" required>
              {friendLinksConfig.categories.map((category) => <option value={category}>{category}</option>)}
            </select>
          </label>
          <label class="form-wide">
            <span>标签 <em>最多 4 个，用英文逗号分隔</em></span>
            <input name="tags" maxlength="68" placeholder="Astro, 写作, 开源" />
          </label>
        </div>
        <label class="agreement">
          <input name="agreement" type="checkbox" required />
          <span>我已阅读申请要求，并确认本站已添加 <a href="/" target="_blank">{siteConfig.name}</a> 的友链。</span>
        </label>
        <div class="form-actions">
          <button class="button button-primary" type="submit">
            <svg viewBox="0 0 24 24" width="1.2em" height="1.2em" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
            前往 GitHub 创建 PR <span aria-hidden="true">↗</span>
          </button>
          <button class="button button-quiet" type="button" data-copy-template>复制资料文本</button>
          <p class="form-message" data-form-message aria-live="polite"></p>
        </div>
      </form>
    </section>

    <section class="guidelines" aria-labelledby="guidelines-title">
      <div class="guidelines-main">
        <p class="eyebrow">GOOD NEIGHBOR GUIDE</p>
        <h2 id="guidelines-title">申请前的小约定</h2>
        <ul>
          {friendLinksConfig.requirements.map((requirement) => <li>{requirement}</li>)}
        </ul>
      </div>
      <aside class="manual-guide">
        <span class="guide-icon" aria-hidden="true">✉</span>
        <div>
          <h3>不会使用 Github？</h3>
          <p>如果你不熟悉上述的自动提交操作，也可以直接将你的站点资料（名称、链接、简介、头像、分类等）发送邮件至 <a href={`mailto:${friendLinksConfig.contactEmail}`}>{friendLinksConfig.contactEmail}</a>，我会手动为你添加。</p>
        </div>
      </aside>
    </section>
  </section>
</BaseLayout>

<script>
  const page = document.querySelector<HTMLElement>('[data-friends-page]');
  const search = document.querySelector<HTMLInputElement>('[data-friend-search]');
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-category]'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-friend-card]'));
  const resultCount = document.querySelector<HTMLElement>('[data-result-count]');
  const noResults = document.querySelector<HTMLElement>('[data-no-results]');
  let activeCategory = 'all';

  const updateDirectory = () => {
    const query = search?.value.trim().toLocaleLowerCase('zh-CN') ?? '';
    let visibleCount = 0;

    cards.forEach((card) => {
      const matchesCategory = activeCategory === 'all' || card.dataset.category === activeCategory;
      const matchesSearch = !query || card.dataset.search?.includes(query);
      const visible = matchesCategory && matchesSearch;
      card.hidden = !visible;
      if (visible) visibleCount += 1;
    });

    if (resultCount) resultCount.textContent = `共 ${visibleCount} 位邻居`;
    if (noResults) noResults.hidden = visibleCount !== 0;
  };

  search?.addEventListener('input', updateDirectory);
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      activeCategory = tab.dataset.category ?? 'all';
      tabs.forEach((item) => {
        const selected = item === tab;
        item.classList.toggle('is-active', selected);
        item.setAttribute('aria-pressed', String(selected));
      });
      updateDirectory();
    });
  });

  const form = document.querySelector<HTMLFormElement>('[data-friend-form]');
  const message = document.querySelector<HTMLElement>('[data-form-message]');
  const copyButton = document.querySelector<HTMLButtonElement>('[data-copy-template]');

  const cleanText = (value: FormDataEntryValue | null) => String(value ?? '').trim().replace(/\s+/g, ' ');
  const quoteYaml = (value: string) => JSON.stringify(value);
  const slugify = (value: string) => {
    const normalized = value
      .normalize('NFKD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '')
      .slice(0, 48);
    return normalized || `friend-${Date.now().toString(36)}`;
  };

  const createSubmission = () => {
    if (!form) return null;
    const values = new FormData(form);
    const name = cleanText(values.get('name'));
    const url = cleanText(values.get('url'));
    const description = cleanText(values.get('description'));
    const avatar = cleanText(values.get('avatar'));
    const category = cleanText(values.get('category'));
    const tags = cleanText(values.get('tags'))
      .split(/[,，]/)
      .map((tag) => tag.trim())
      .filter(Boolean)
      .slice(0, 4);
    const date = new Date().toISOString().slice(0, 10);
    const markdown = [
      '---',
      `name: ${quoteYaml(name)}`,
      `url: ${quoteYaml(url)}`,
      `description: ${quoteYaml(description)}`,
      `avatar: ${quoteYaml(avatar)}`,
      `category: ${quoteYaml(category)}`,
      'tags:',
      ...(tags.length ? tags.map((tag) => `  - ${quoteYaml(tag)}`) : ['  - "个人站点"']),
      `submittedAt: ${date}`,
      '---',
      '',
      '由友链页面自动生成。',
      '',
    ].join('\n');
    return { markdown, filename: `${slugify(name)}.md` };
  };

  const showMessage = (text: string, isError = false) => {
    if (!message) return;
    message.textContent = text;
    message.classList.toggle('is-error', isError);
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      showMessage('请先补全必填资料。', true);
      return;
    }

    const submission = createSubmission();
    if (!submission || !page) return;
    const repository = page.dataset.repository;
    const branch = page.dataset.branch;
    const directory = page.dataset.directory;
    if (!repository || !branch || !directory) return;

    const file = `${directory}/${submission.filename}`;
    const target = new URL(`https://github.com/${repository}/new/${branch}`);
    target.searchParams.set('filename', file);
    target.searchParams.set('value', submission.markdown);
    showMessage('正在打开 GitHub；如提示 Fork，请确认后继续创建 Pull Request。');
    window.location.assign(target.toString());
  });

  copyButton?.addEventListener('click', async () => {
    if (!form) return;
    if (!form.checkValidity()) {
      form.reportValidity();
      showMessage('请先补全必填资料。', true);
      return;
    }
    const submission = createSubmission();
    if (!submission) return;
    try {
      await navigator.clipboard.writeText(submission.markdown);
      showMessage(`已复制 ${submission.filename} 的内容。`);
    } catch {
      showMessage('复制失败，请改用“前往 GitHub 创建 PR”。', true);
    }
  });

  const siteInfoCopyBtn = document.querySelector<HTMLButtonElement>('[data-copy-site-info]');
  siteInfoCopyBtn?.addEventListener('click', async () => {
    const pre = siteInfoCopyBtn.nextElementSibling;
    if (pre && pre.tagName.toLowerCase() === 'pre') {
      try {
        await navigator.clipboard.writeText(pre.textContent || '');
        const originalText = siteInfoCopyBtn.textContent;
        siteInfoCopyBtn.textContent = '已复制!';
        siteInfoCopyBtn.classList.add('is-copied');
        setTimeout(() => {
          siteInfoCopyBtn.textContent = originalText;
          siteInfoCopyBtn.classList.remove('is-copied');
        }, 2000);
      } catch (err) {
        console.error('Failed to copy', err);
      }
    }
  });
</script>

<style>
  .friends-page { width: min(100% - (var(--page-gutter) * 2), 72rem); margin: 0 auto; padding: clamp(2.25rem, 5vw, 4.5rem) 0 6rem; }
  .friends-hero { position: relative; display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(18rem, 0.8fr); gap: clamp(1.5rem, 4vw, 4rem); overflow: hidden; border: 1px solid rgb(154 133 95 / 34%); border-radius: clamp(1.5rem, 3vw, 2.4rem); background: linear-gradient(125deg, rgb(255 251 232 / 92%), rgb(226 245 227 / 90%)); padding: clamp(1.8rem, 5vw, 4rem); isolation: isolate; }
  .friends-hero::before { position: absolute; inset: 0; z-index: -1; background-image: radial-gradient(rgb(95 133 93 / 13%) 1px, transparent 1px); background-size: 13px 13px; content: ''; opacity: .72; }
  .hero-copy { max-width: 38rem; }
  .eyebrow { display: flex; align-items: center; gap: .38rem; margin: 0 0 .5rem; color: #6a9470; font-size: .7rem; font-weight: 900; letter-spacing: .13em; line-height: 1.3; }
  h1, h2, h3 { color: var(--color-text); font-weight: 900; letter-spacing: -.035em; }
  .friends-hero h1 { margin: 0; font-size: clamp(2.35rem, 5vw, 4.6rem); line-height: 1.05; }
  .friends-hero p:not(.eyebrow) { max-width: 34rem; margin: 1rem 0 0; color: var(--color-text-body); font-size: clamp(1rem, 2vw, 1.14rem); }
  .hero-actions, .form-actions { display: flex; flex-wrap: wrap; align-items: center; gap: .75rem; margin-top: 1.6rem; }
  .button { display: inline-flex; min-height: 2.9rem; align-items: center; justify-content: center; gap: .4rem; border: 1px solid transparent; border-radius: var(--radius-pill); padding: .64rem 1.05rem; font: inherit; font-size: .9rem; font-weight: 900; line-height: 1.2; text-decoration: none; cursor: pointer; transition: transform var(--motion-duration) var(--motion-easing), background var(--motion-duration) var(--motion-easing), box-shadow var(--motion-duration) var(--motion-easing); }
  .button:hover { transform: translateY(-2px); }
  .button:focus-visible, input:focus-visible, textarea:focus-visible, select:focus-visible, .category-tab:focus-visible { outline: 3px solid var(--color-focus); outline-offset: 3px; }
  .button-primary { background: linear-gradient(135deg, #1bbbab, #0fa99c); box-shadow: 0 .23rem 0 #087b72, inset 0 1px rgb(255 255 255 / 32%); color: #fff; }
  .button-primary:hover { box-shadow: 0 .34rem 0 #087b72, inset 0 1px rgb(255 255 255 / 32%); color: #fff; }
  .button-quiet { border-color: rgb(108 128 83 / 32%); background: rgb(255 255 255 / 57%); color: var(--color-text); }
  .button-quiet:hover { background: rgb(255 255 255 / 90%); color: var(--color-text); }
  .island-stats { display: grid; align-content: center; gap: .8rem; margin: 0; }
  .island-stats div { display: grid; grid-template-columns: 1fr auto; align-items: baseline; gap: 1rem; border-bottom: 1px dashed rgb(109 128 83 / 35%); padding: .58rem 0; }
  .island-stats dt { color: var(--color-text-muted); font-size: .82rem; font-weight: 800; }
  .island-stats dd { margin: 0; color: #527f5c; font-size: 1.65rem; font-weight: 900; line-height: 1; }
  .island-stats .latest-date { font-size: .86rem; line-height: 1.3; text-align: right; }
  .hero-decoration { position: absolute; z-index: -1; color: rgb(86 149 110 / 16%); font-family: Georgia, serif; font-size: 9rem; line-height: 1; pointer-events: none; }
  .hero-decoration-leaf { right: 40%; bottom: -4.5rem; transform: rotate(-30deg); }
  .hero-decoration-star { top: 1rem; right: 1.4rem; font-size: 3.5rem; }
  .friend-directory { margin-top: clamp(3.5rem, 8vw, 6rem); }
  .section-heading { display: flex; align-items: end; justify-content: space-between; gap: 1.5rem; }
  .section-heading h2, .join-intro h2, .guidelines h2 { margin: 0; font-size: clamp(1.75rem, 3vw, 2.4rem); line-height: 1.1; }
  .friend-search { display: flex; width: min(100%, 18rem); align-items: center; gap: .5rem; border: 1px solid rgb(126 105 78 / 30%); border-radius: var(--radius-pill); background: rgb(255 255 255 / 55%); padding: 0 .8rem; transition: border-color var(--motion-duration) var(--motion-easing), background var(--motion-duration) var(--motion-easing); }
  .friend-search:focus-within { border-color: var(--color-primary); background: #fffdf4; }
  .friend-search svg { width: 1.1rem; height: 1.1rem; fill: none; stroke: var(--color-text-muted); stroke-linecap: round; stroke-width: 1.8; }
  .friend-search input { width: 100%; min-height: 2.75rem; border: 0; outline: 0; background: transparent; color: var(--color-text); font: inherit; font-size: .87rem; }
  .directory-controls { display: flex; align-items: center; justify-content: space-between; gap: 1rem; margin: 1.5rem 0; }
  .category-tabs { display: flex; flex-wrap: wrap; gap: .45rem; }
  .category-tab { border: 1px solid rgb(126 105 78 / 24%); border-radius: var(--radius-pill); background: rgb(255 255 255 / 48%); padding: .38rem .7rem; color: var(--color-text-body); font: inherit; font-size: .77rem; font-weight: 800; cursor: pointer; transition: background var(--motion-duration) var(--motion-easing), color var(--motion-duration) var(--motion-easing); }
  .category-tab span { opacity: .65; }
  .category-tab:hover, .category-tab.is-active { border-color: transparent; background: #8fa3c8; color: #fff; }
